{
  "name": "Neue Dashboard",
  "version": "1.5.2",
  "slug": "neue-dashboard-addon",
  "description": "Custom Home Assistant dashboard with MQTT control",
  "url": "https://github.com/neue-supply/ha-dashboard",
  "arch": ["aarch64", "amd64", "armv7"],
  "init": false,
  "ingress": true,
  "ingress_port": 8099,
  "ingress_stream": true,
  "startup": "application",
  "boot": "auto",
  "homeassistant_api": true,
  "map": ["config:ro"],
  "options": {
    "document_root": "/config/www/neue-dashboard",
    "mqtt_server": "ws://10.0.30.30:1884",
    "go2rtc_url": "http://10.0.30.33:1984",
    "ha_url": "http://supervisor/core"
  },
  "schema": {
    "document_root": "str",
    "mqtt_server": "str",
    "go2rtc_url": "str?",
    "ha_url": "str?"
  }
}
